---
// @ts-nocheck
import MainLayout from "../layout.astro/MainLayout.astro";

const id = Astro.url.searchParams.get("eventId");
const ticketmasterApi = import.meta.env.TM_KEY;
const base = `https://app.ticketmaster.com/discovery/v2/events/${id}.json?apikey=${ticketmasterApi}`;

const response = await fetch(base);
const data = await response.json();

const venue = data._embedded?.venues?.[0];
const prijs = data.priceRanges?.[0];
const genre = data.classifications?.[0]?.genre?.name;
const segment = data.classifications?.[0]?.segment?.name;

// chatgpt: hoe kan ik de datum in afkorting op me website laten tonen en met hoofdletters.
const datum = new Date(data.dates?.start?.localDate);
const dag = datum.getDate();

const maand = datum.toLocaleString("nl-NL", { month: "short" }).toUpperCase();

const tijd = data.dates?.start?.localTime.slice(0, 5);

const statusLabels = {
    onsale: "ON SALE", 
    offsale: "UITVERKOCHT",
    canceled: "GEANNULEERD", 
    postponed: "UITGESTELD",
};
const status = statusLabels[data.dates?.status?.code] || data.dates?.status?.code;
---

<MainLayout>
  <main>

    <header>
      <p>TICKETMASTER · NEDERLAND</p>
      <h1>{data.name}</h1>
      <p>+ LIVE IN CONCERT +</p>
      <!-- bron voor small text ; https://developer.mozilla.org/en-US/docs/Web/HTML/Reference/Elements/small -->
      {segment && genre && <small>{segment} · {genre}</small>}
    </header>

    <div class="tussenTicket"></div>

    <section>

      <article>
        <small>LOCATIE</small>
        {venue && <h2>{venue.name}</h2>}
        {venue && <p>{venue.address?.line1}, {venue.city?.name}</p>}
      </article>

      <p class="dagMaand">
        <strong>{dag}</strong>
        <span>{maand}</span>
      </p>

    </section>

    <section>

      {tijd && (
        <article>
          <small>AANVANG</small>
          <strong>{tijd}</strong>
        </article>
      )}

      <article>
        <small>STATUS</small>
        <strong>{status}</strong>
      </article>
      
    </section>

    <div class="ticketResale">
      <small>UNAUTHORISED RESALE PROHIBITED</small>
      <a href={data.url} target="_blank">KOOP TICKETS →</a>
    </div>

  </main>
</MainLayout>

<style>

main {
  width: 340px;
  margin: 3rem auto;
  font-family: 'IBM Plex Mono', monospace;
  border-radius: 16px;
  overflow: hidden;
}

header {
  background: linear-gradient(135deg, #c8f0f8, #e8d5f5, #fde8c8, #d5f5e8, #c8d5f8);
  padding: 1.5rem;
  text-align: center;
}

header h1 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 72px;
  line-height: 1;
  color: #111;
  margin: 0.25rem 0;
  letter-spacing: -2px;
}

header p {
  font-size: 10px;
  letter-spacing: 3px;
  color: #333;
  margin: 0.25rem 0;
}

header small {
  /* display: inline-block; */
  border: 1px solid #333;
  font-size: 10px;
  letter-spacing: 2px;
  padding: 3px 10px;
  color: #333;
}

.tussenTicket {
  border-top: 2px dashed #444;
}

section {
  background: #f5f0e8;
  padding: 1.25rem;
}

section:first-of-type {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  border-bottom: 1px solid #ccc;
  padding-bottom: 1rem;
}

section:last-of-type {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  padding-top: 1rem;
}

article small {
  font-size: 8px;
  letter-spacing: 2px;
  color: #888;
  display: block;
  margin-bottom: 2px;
}

article strong {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 28px;
}

section:first-of-type article h2 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 22px;
  color: black;
  margin: 0;
}

section:first-of-type article p {
  font-size: 9px;
  color: #666;
  margin: 2px 0 0;
  letter-spacing: 1px;
}

.dagMaand {
  text-align: right;
}

.dagMaand strong {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 48px;
  color: #111;
  line-height: 1;
  display: block;
}

.dagMaand span {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 22px;
  color: #111;
}

.ticketResale {
  background: #f5f0e8;
  padding: 0.75rem 1.25rem;
  border-top: 1px solid #ccc;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.ticketResale small {
  font-size: 8px;
  color: #999;
  letter-spacing: 1px;
}

.ticketResale a {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 16px;
  color: #111;
  text-decoration: none;
}
</style>